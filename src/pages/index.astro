---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublishedPosts } from '../utils/posts';
import { SITE_DESCRIPTION } from '../consts';

const latest = (await getPublishedPosts()).slice(0, 5);
const dateFormatter = new Intl.DateTimeFormat('ar', { dateStyle: 'long', numberingSystem: 'latn' });
---

<BaseLayout>
  <section class="mb-10">
    <h1 class="mb-3 text-2xl font-bold">أهلًا بك</h1>
    <p class="max-w-prose text-zinc-700 dark:text-zinc-300">{SITE_DESCRIPTION}</p>
  </section>

  <section>
    <h2 class="mb-4 text-xl font-semibold">أحدث التدوينات</h2>
    <ul class="space-y-5">
      {
        latest.map((post) => (
          <li>
            <a href={`/blog/${post.id}/`} class="font-semibold text-accent hover:underline">
              {post.data.title}
              {post.data.draft && (
                <span class="ms-2 text-sm font-normal text-amber-700 dark:text-amber-300">
                  (مسودة)
                </span>
              )}
            </a>
            <p class="text-sm text-zinc-500 dark:text-zinc-400">
              {dateFormatter.format(post.data.pubDate)}
            </p>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
