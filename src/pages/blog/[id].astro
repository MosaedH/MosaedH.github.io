---
import { render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import { getPublishedPosts } from '../../utils/posts';
import { getRelatedPosts } from '../../utils/related';
import { readingTimeMinutes } from '../../utils/reading-time';
import { absoluteUrl } from '../../utils/url';
import { TAGS } from '../../data/tags';
import { AUTHOR } from '../../consts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post, related: getRelatedPosts(post, posts) },
  }));
}

const { post, related } = Astro.props;
const { Content, headings } = await render(post);
const minutes = readingTimeMinutes(post.body ?? '');
const dateFormatter = new Intl.DateTimeFormat('ar', { dateStyle: 'long', numberingSystem: 'latn' });

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  ...(post.data.updatedDate && { dateModified: post.data.updatedDate.toISOString() }),
  author: { '@type': 'Person', name: AUTHOR },
  inLanguage: 'ar',
  mainEntityOfPage: absoluteUrl(`/blog/${post.id}/`),
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  jsonLd={jsonLd}
>
  <!-- Reading progress bar: logical inset, grows from the reading start (right in RTL). -->
  <div id="progress" class="fixed start-0 top-0 z-40 h-0.5 w-0 bg-accent" aria-hidden="true"></div>

  <div class="mx-auto lg:grid lg:max-w-5xl lg:grid-cols-[1fr_14rem] lg:gap-10">
    <article class="prose mx-auto min-w-0">
      <header>
        {
          post.data.draft && (
            <p class="inline-block rounded bg-amber-100 px-2 py-0.5 text-sm text-amber-900 dark:bg-amber-900 dark:text-amber-100">
              مسودة — لا تُنشر في الموقع النهائي
            </p>
          )
        }
        <h1>{post.data.title}</h1>
        <!-- Keep this on one line: newline-separated whitespace between inline elements
             is what 'jsx' compression strips (compressHTML: true also guards this). -->
        <p class="text-sm text-zinc-500 dark:text-zinc-400">
          نُشر في <time datetime={post.data.pubDate.toISOString()}
            >{dateFormatter.format(post.data.pubDate)}</time
          > — وقت القراءة <span>{minutes}</span>
          {minutes <= 10 && minutes >= 3 ? 'دقائق' : 'دقيقة'} تقريبًا
        </p>
        {
          post.data.updatedDate && (
            <p class="text-sm text-zinc-500 dark:text-zinc-400">
              آخر تحديث{' '}
              <time datetime={post.data.updatedDate.toISOString()}>
                {dateFormatter.format(post.data.updatedDate)}
              </time>
            </p>
          )
        }
        <ul class="flex list-none flex-wrap gap-2 p-0">
          {
            post.data.tags.map((tag) => (
              <li>
                <a
                  href={`/tags/${tag}/`}
                  class="rounded bg-zinc-100 px-2 py-0.5 text-sm no-underline hover:text-accent dark:bg-zinc-800"
                >
                  {TAGS[tag]}
                </a>
              </li>
            ))
          }
        </ul>
      </header>

      <!-- Mobile TOC: in-flow before the content. -->
      <div class="my-6 lg:hidden">
        <TableOfContents headings={headings} />
      </div>

      <Content />

      {
        related.length > 0 && (
          <footer class="mt-12 border-t border-zinc-200 pt-6 dark:border-zinc-700">
            <h2 class="text-lg font-semibold">تدوينات ذات صلة</h2>
            <ul class="mt-3 list-none space-y-2 p-0">
              {related.map((rel) => (
                <li>
                  <a href={`/blog/${rel.id}/`} class="text-accent hover:underline">
                    {rel.data.title}
                  </a>
                </li>
              ))}
            </ul>
          </footer>
        )
      }
    </article>

    <!-- Desktop TOC: sticky in the side column (inline-end = left in RTL). -->
    <aside class="hidden lg:block">
      <div class="sticky top-8">
        <TableOfContents headings={headings} />
      </div>
    </aside>
  </div>

  <script>
    // Reading progress: a few lines of vanilla JS, no library (NEW_PLAN §5).
    const bar = document.getElementById('progress');
    const update = () => {
      const max = document.documentElement.scrollHeight - innerHeight;
      if (bar) bar.style.width = `${max > 0 ? Math.min(100, (scrollY / max) * 100) : 0}%`;
    };
    addEventListener('scroll', update, { passive: true });
    update();
  </script>
</BaseLayout>
