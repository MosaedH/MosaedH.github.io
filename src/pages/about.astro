        <tr><td>تم</td><td>eJPTv2</td></tr>
        <tr><td>تم</td><td>CompTIA Security +</td></tr>
        <tr><td>تم</td><td>CompTIA Network +</td></tr>
        <tr><td>تم</td><td>ITIL</td></tr>
